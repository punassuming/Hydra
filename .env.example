ADMIN_TOKEN=
ADMIN_DOMAIN=admin

# Scheduler Redis auth (global requirepass, not per-domain ACL).
# Leave empty if Redis has no requirepass (the default Docker setup).
# This is distinct from REDIS_PASSWORD, which is the per-domain worker ACL password.
# SCHEDULER_REDIS_PASSWORD=

# First-startup domain seeding (scheduler only).
# On a fresh deployment with an empty database the scheduler seeds one domain automatically.
# Pre-set these to bootstrap with known credentials so workers connect immediately.
# SEED_DOMAIN=prod
# SEED_DOMAIN_TOKEN=<api_token_for_that_domain>
# SEED_DOMAIN_REDIS_PASSWORD=<redis_acl_password_for_that_domain>

# Worker minimal env (when WORKER_REQUIRE_REDIS_ACL=true):
# DOMAIN=prod
# API_TOKEN=<domain_api_token>
# REDIS_PASSWORD=<domain_redis_acl_password>
# REDIS_URL=redis://redis:6379/0
# REDIS_SENTINELS=redis-sentinel-1:26379,redis-sentinel-2:26379,redis-sentinel-3:26379
# REDIS_SENTINEL_MASTER=mymaster
# REDIS_DB=0
# REDIS_SOCKET_TIMEOUT=2
# REDIS_SENTINEL_USERNAME=
# REDIS_SENTINEL_PASSWORD=
# MONGO_URL=mongodb://mongo:27017

# Non-containerized worker execution (optional — omit when running in Docker):
# HYDRA_PYTHON_PATH=/opt/python3.11/bin/python3
# HYDRA_SHELL_PATH=/usr/local/bin/bash
# HYDRA_GIT_PATH=/usr/local/bin/git
# HYDRA_TEMP_DIR=/var/tmp/hydra
