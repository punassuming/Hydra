# =============================================================================
# Hydra Jobs — environment variable reference
# =============================================================================
# Copy this file to .env and fill in the values for your deployment.
# Variables marked [REQUIRED] must be set; all others have safe defaults.
# =============================================================================


# =============================================================================
# SCHEDULER
# =============================================================================

# [REQUIRED] Admin token — grants cross-domain access to /admin/* endpoints.
# Changing this in production invalidates all currently-issued admin sessions.
ADMIN_TOKEN=

# Domain name reserved for admin operations (default: "admin").
# Change only if your tenant namespace uses a different admin domain name.
# ADMIN_DOMAIN=admin

# Credential encryption key — used to encrypt stored credentials (DB URIs,
# PAT tokens, SMTP passwords). Must be a base64-url-encoded 32-byte value.
#
# IMPORTANT: If not set, the key is derived from ADMIN_TOKEN. This means that
# rotating ADMIN_TOKEN will make all stored credentials permanently unreadable.
# Set this to a stable, independently-managed value for production.
#
# Generate: python -c "import secrets,base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
# CREDENTIAL_ENCRYPTION_KEY=

# Scheduler Redis auth (global requirepass, not per-domain ACL).
# Leave empty if Redis has no requirepass (the default Docker setup).
# SCHEDULER_REDIS_PASSWORD=

# CORS origins allowed to call the scheduler API (comma-separated or *).
# Required when the UI is served from a different host/port than the API.
# CORS_ALLOW_ORIGINS=http://localhost:5173

# First-startup domain seeding (scheduler only).
# On a fresh deployment with an empty database the scheduler seeds one domain.
# Pre-set these so workers can connect immediately on first boot.
# SEED_DOMAIN=prod
# SEED_DOMAIN_TOKEN=<api_token_for_that_domain>
# SEED_DOMAIN_REDIS_PASSWORD=<redis_acl_password_for_that_domain>

# AI features (optional — enables job generation and log analysis).
# GEMINI_API_KEY=
# OPENAI_API_KEY=


# =============================================================================
# WORKER
# =============================================================================

# [REQUIRED] Domain the worker belongs to.
# DOMAIN=prod

# [REQUIRED] Domain API token — obtained from the Admin panel or
#   POST /admin/domains/<domain>/token
# API_TOKEN=

# [REQUIRED when WORKER_REQUIRE_REDIS_ACL=true] Per-domain Redis ACL password.
# Rotate via POST /admin/domains/<domain>/redis_acl/rotate
# REDIS_PASSWORD=

# Redis connection (use REDIS_URL for standalone, or REDIS_SENTINELS for HA).
# REDIS_URL=redis://redis:6379/0
# REDIS_SENTINELS=redis-sentinel-1:26379,redis-sentinel-2:26379,redis-sentinel-3:26379
# REDIS_SENTINEL_MASTER=mymaster
# REDIS_DB=0
# REDIS_SOCKET_TIMEOUT=2
# REDIS_SENTINEL_USERNAME=
# REDIS_SENTINEL_PASSWORD=

# Whether to require Redis ACL credentials (recommended: true).
# Set to false only for local dev environments without ACL configured.
# WORKER_REQUIRE_REDIS_ACL=true

# Unique worker identifier. Defaults to worker-<hostname>.
# Set explicitly when running multiple workers on the same host so they get
# distinct IDs (e.g. WORKER_ID=worker-host-1, WORKER_ID=worker-host-2).
# WORKER_ID=

# Comma-separated affinity tags (used for job routing).
# WORKER_TAGS=linux,gpu,high-mem

# Maximum number of concurrent jobs this worker will accept.
# MAX_CONCURRENCY=2

# Initial worker dispatch state on startup: online | draining | offline
# WORKER_STATE=online

# Deployment type label shown in the UI.
# DEPLOYMENT_TYPE=standalone


# =============================================================================
# NON-CONTAINERIZED WORKER EXECUTION
# Override these when running workers outside Docker (bare-metal, VMs).
# =============================================================================
# HYDRA_PYTHON_PATH=/opt/python3.11/bin/python3
# HYDRA_SHELL_PATH=/usr/local/bin/bash
# HYDRA_GIT_PATH=/usr/local/bin/git
# HYDRA_TEMP_DIR=/var/tmp/hydra


# =============================================================================
# UI
# =============================================================================

# Base URL of the scheduler API as seen from the browser (not the container).
# Must be set at UI build time (Vite bakes it in).
# VITE_API_BASE_URL=http://localhost:8000


# =============================================================================
# MONGODB (scheduler only)
# =============================================================================
# MONGO_URL=mongodb://mongo:27017
# MONGO_DB=hydra_jobs
